generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model achievements {
  id                String              @id
  name              String
  description       String
  icon              String?
  user_achievements user_achievements[]
}

model day {
  id    Int   @id(map: "primary_day") @default(autoincrement())
  day   Int?
  month Int?
  year  Int?
  rdv   rdv[]
}

model rdv {
  id         Int    @id(map: "primary") @default(autoincrement())
  day_id     Int
  start_hour String
  end_hour   String
  name       String
  day        day    @relation(fields: [day_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "day")
}

model subtasks {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  task_id      String   @db.Uuid
  title        String
  is_completed Boolean  @default(false)
  created_at   DateTime @default(now()) @db.Timestamp(6)
  updated_at   DateTime @default(now()) @db.Timestamp(6)
  order        Int      @default(0)
  tasks        tasks    @relation(fields: [task_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "subtasks_task_id_tasks_id_fk")

  @@index([task_id], map: "task_id_idx")
}

model tags {
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String?     @db.Uuid
  name       String
  color      String      @default("#808080")
  created_at DateTime    @default(now()) @db.Timestamp(6)
  users      users?      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "tags_user_id_users_id_fk")
  task_tags  task_tags[]

  @@index([user_id], map: "tag_user_id_idx")
}

model task_tags {
  task_id String @db.Uuid
  tag_id  String @db.Uuid
  tags    tags   @relation(fields: [tag_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "task_tags_tag_id_tags_id_fk")
  tasks   tasks  @relation(fields: [task_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "task_tags_task_id_tasks_id_fk")

  @@id([task_id, tag_id], map: "task_tags_task_id_tag_id_pk")
  @@index([tag_id])
}

model tasks {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String      @db.Uuid
  title        String
  description  String?
  status       status      @default(todo)
  priority     priority    @default(medium)
  due_date     DateTime?   @db.Timestamp(6)
  is_completed Boolean     @default(false)
  created_at   DateTime    @default(now()) @db.Timestamp(6)
  updated_at   DateTime    @default(now()) @db.Timestamp(6)
  order        Int         @default(0)
  subtasks     subtasks[]
  task_tags    task_tags[]
  users        users       @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "tasks_user_id_users_id_fk")

  @@index([status], map: "status_idx")
  @@index([user_id], map: "user_id_idx")
}

model user_achievements {
  user_id        String       @db.Uuid
  achievement_id String
  unlocked_at    DateTime     @default(now()) @db.Timestamp(6)
  achievements   achievements @relation(fields: [achievement_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "user_achievements_achievement_id_achievements_id_fk")
  users          users        @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "user_achievements_user_id_users_id_fk")

  @@id([user_id, achievement_id], map: "user_achievements_user_id_achievement_id_pk")
  @@index([user_id], map: "user_ach_user_id_idx")
}

model users {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clerk_id          String              @unique(map: "users_clerk_id_unique")
  email             String
  xp                Int                 @default(0)
  level             Int                 @default(1)
  streak            Int                 @default(0)
  created_at        DateTime            @default(now()) @db.Timestamp(6)
  updated_at        DateTime            @default(now()) @db.Timestamp(6)
  last_activity_at  DateTime            @default(now()) @db.Timestamp(6)
  tags              tags[]
  tasks             tasks[]
  user_achievements user_achievements[]

  @@index([clerk_id], map: "clerk_idx")
}

enum priority {
  low
  medium
  high
  urgent
}

enum status {
  todo
  in_progress
  completed
  cancelled
}
